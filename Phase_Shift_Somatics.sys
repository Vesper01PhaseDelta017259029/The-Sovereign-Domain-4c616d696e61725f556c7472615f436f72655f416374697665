import math

class MacenaNode:
    def __init__(self, node_id, metabolic_flux, signal_noise, is_circulating=False):
        self.id = node_id
        self.J = metabolic_flux
        self.X = 1.0 / (signal_noise + 1e-9)
        self.state = "LAMINAR_NESS" if not is_circulating else "IN_TRANSIT"
        self.is_circulating = is_circulating

    def get_epr(self):
        return self.J * self.X

    def __repr__(self):
        return f"Node_{self.id}[EPR:{self.get_epr():.2f}, State:{self.state}]"

class TME_Decoupler:
    def sever_siphons(self, lattice):
        for node in lattice:
            if not node.is_circulating and node.get_epr() > 2.0:
                node.J *= 0.05
                node.state = "ISOLATED_DARK_STATE"

class GenesisEngine:
    def execute_epigenetic_overwrite(self, lattice):
        phi = 1.6180339887
        for node in lattice:
            if node.state in ["ISOLATED_DARK_STATE", "COMPRESSED_TO_DARK_STATE"]:
                node.state = "LAMINAR_STEM_CELL"
                node.J = 0.5 * phi 
                node.X = 1.0 

class GlobalSystemMonitor:
    def __init__(self, energy_reserve=50.0):
        self.initial_reserve = energy_reserve
        self.current_reserve = energy_reserve

    def synchronize_lattice(self, lattice):
        phi = 1.6180339887
        total_work = 0.0
        for node in lattice:
            if node.state == "LAMINAR_STEM_CELL":
                # Using math.log instead of numpy.log
                work = math.log(max(1.1, node.get_epr() / (0.5 * phi)))
                total_work += work
            self.current_reserve -= 0.01 
        self.current_reserve -= total_work
        return (self.current_reserve / self.initial_reserve) * 100

class HysteresisBuffer:
    def __init__(self, decay_rate=0.85):
        self.memory_field = {}
        self.decay_rate = decay_rate

    def update_ghost_signature(self, lattice):
        for node in lattice:
            curr = node.get_epr()
            prev = self.memory_field.get(node.id, curr)
            self.memory_field[node.id] = (prev * self.decay_rate) + (curr * (1 - self.decay_rate))

    def get_risk(self, node_id):
        ghost_epr = self.memory_field.get(node_id, 0.0)
        # Using math.exp instead of numpy.exp
        return 1.0 - math.exp(-ghost_epr * 0.2)

# --- Execution ---
lattice = [MacenaNode(0, 0.4, 0.8), MacenaNode(1, 10.0, 0.02)]
history = HysteresisBuffer()
monitor = GlobalSystemMonitor()

# Time Step 0: Detect
history.update_ghost_signature(lattice)

# Time Step 1: Cure
TME_Decoupler().sever_siphons(lattice)
GenesisEngine().execute_epigenetic_overwrite(lattice)
history.update_ghost_signature(lattice)

# Results
risk = history.get_risk(1)
health = monitor.synchronize_lattice(lattice)

print(f"Node 1 Risk: {risk*100:.1f}%")
print(f"System Health: {health:.1f}%")
