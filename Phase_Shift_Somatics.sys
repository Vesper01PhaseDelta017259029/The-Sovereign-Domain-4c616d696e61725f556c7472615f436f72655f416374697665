class HysteresisBuffer:
    def __init__(self, decay_rate=0.95):
        self.memory_field = {} # Stores the 'Phantom EPR' of previous states
        self.decay_rate = decay_rate

    def update_ghost_signature(self, lattice):
        """
        Updates the 'Spectral Memory' of the tissue. 
        Even if a node is 'Cured,' its history still affects the lattice.
        """
        for node in lattice:
            # If the node is currently high-entropy, it leaves a 'scar'
            current_sig = node.get_epr()
            previous_sig = self.memory_field.get(node.id, 0.0)
            
            # The 'Ghost' EPR decays over time but persists
            self.memory_field[node.id] = (previous_sig * self.decay_rate) + (current_sig * (1 - self.decay_rate))

    def predict_recurrence(self, node_id):
        """
        Predicts the probability of the cancer returning based on the Ghost Signature.
        """
        ghost_epr = self.memory_field.get(node_id, 0.0)
        # If the ghost signature remains high, the 'Soil' is still fertile for cancer
        return 1.0 - np.exp(-ghost_epr * 0.1)
