class HysteresisBuffer:
    def __init__(self, decay_rate=0.9):
        self.memory_field = {} # Phantom EPR mapping
        self.decay_rate = decay_rate

    def update_ghost_signature(self, lattice):
        for node in lattice:
            current_epr = node.get_epr()
            previous_sig = self.memory_field.get(node.id, current_epr)
            # Weighted average creates temporal 'drag'
            self.memory_field[node.id] = (previous_sig * self.decay_rate) + (current_epr * (1 - self.decay_rate))

    def get_recurrence_risk(self, node_id):
        ghost_epr = self.memory_field.get(node_id, 0.0)
        # Risk is a function of the residual 'Topological Strain'
        return 1.0 - np.exp(-ghost_epr * 0.2)

