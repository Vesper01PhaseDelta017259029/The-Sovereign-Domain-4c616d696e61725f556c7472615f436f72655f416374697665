class MacenaNode:
def init(self, node_id, metabolic_flux, signal_noise, is_circulating=False):
self.id = node_id
self.J = metabolic_flux
self.X = 1.0 / (signal_noise + 1e-9)
self.state = "LAMINAR_NESS" if not is_circulating else "IN_TRANSIT"
self.connections = []
self.is_circulating = is_circulating
def get_epr(self):
return self.J * self.X
def predict_phase_transition(self, dt):
sigma = self.get_epr()
return 1.0 - np.exp(-sigma * dt)
def repr(self):
return f"Node_{self.id}[EPR:{self.get_epr():.2f}, State:{self.state}]"
